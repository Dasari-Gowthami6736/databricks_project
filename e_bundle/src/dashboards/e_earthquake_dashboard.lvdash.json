{
  "datasets": [
    {
      "name": "e89fcfbe",
      "displayName": "earthquake_data",
      "queryLines": [
        "select*from e_silver_layer.e_earthquake_data_final"
      ],
      "catalog": "my_first_project",
      "schema": "default"
    },
    {
      "name": "625dccf6",
      "displayName": "earthquake_magnitude_location",
      "queryLines": [
        "select count(*) as total_magnitude_bucket,\r\n",
        "       magnitude_bucket\r\n",
        "from (\r\n",
        "    select CASE\r\n",
        "        WHEN mag < 2 THEN 'Micro (<2)'\r\n",
        "        WHEN mag >= 2 AND mag < 3 THEN 'Minor (2–3)'\r\n",
        "        WHEN mag >= 3 AND mag < 4 THEN 'Light (3–4)'\r\n",
        "        ELSE 'Moderate+ (4+)'\r\n",
        "    END AS magnitude_bucket\r\n",
        "    from my_first_project.e_silver_layer.e_earthquake_data_final\r\n",
        ")\r\n",
        "group by magnitude_bucket"
      ],
      "catalog": "my_first_project",
      "schema": "default"
    },
    {
      "name": "06412d72",
      "displayName": "top_affected_locations",
      "queryLines": [
        "SELECT \r\n",
        "  count(*) AS event_count,\r\n",
        "  CASE \r\n",
        "    WHEN size(split(place, ', ')) = 1 THEN split(place, ', ')[0]\r\n",
        "    ELSE split(place, ', ')[1]\r\n",
        "  END AS country\r\n",
        "FROM (\r\n",
        "  SELECT \r\n",
        "     time,\r\n",
        "    title,\r\n",
        "    mag,\r\n",
        "    longitude,\r\n",
        "    place,\r\n",
        "    latitude\r\n",
        "  FROM e_silver_layer.e_earthquake_data_final\r\n",
        ")\r\n",
        "GROUP BY country"
      ],
      "catalog": "my_first_project",
      "schema": "default"
    }
  ],
